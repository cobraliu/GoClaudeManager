# Embedded SPA bundle: the `dist/` rule above hides internal/web/dist, but the
# placeholder must stay tracked so `go build` works on a fresh clone. Re-include
# the placeholder; keep the real content-hashed Vite output ignored.
!internal/web/dist/
!internal/web/dist/index.html
internal/web/dist/assets/*
!internal/web/dist/assets/.gitkeep

